# Copy to .env for local development.
PORT=4000
# Comma-separated list of allowed CORS origins (frontend dev server).
CORS_ORIGIN=http://localhost:3000
# Secret used to sign JWT auth tokens. Set a strong value in production.
JWT_SECRET=dev-secret-change-me
# Optional: when set, the API also serves the frontend SPA build from this dir
# (the combined Docker image sets it automatically). Leave unset for API-only.
# CLIENT_BUILD_DIR=/app/frontend/build
