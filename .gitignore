# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (any workspace: frontend/, backend/)
node_modules
.pnp
.pnp.js

# testing
coverage

# build output (frontend/build, backend/dist)
build/
dist/

# vite / typescript
*.tsbuildinfo
.vite

# editor / os
.DS_Store
.idea
.vscode/*
!.vscode/extensions.json

# env (keep committed .env / .env.example; ignore local overrides + secrets)
.env.local
.env.*.local
backend/.env

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# netlify / docker
.netlify
